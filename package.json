{
  "name": "@kayxean/chromatrix",
  "version": "1.0.4",
  "private": false,
  "description": "CIEXYZ-based color engine using Float32Array matrix pooling",
  "keywords": [
    "accessibility",
    "color",
    "contrast",
    "conversion",
    "palette"
  ],
  "homepage": "https://github.com/kayxean/chromatrix#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kayxean/chromatrix.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.mts",
      "import": "./dist/adapters/*.mjs"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.mts",
      "import": "./dist/utils/*.mjs"
    },
    "./convert": {
      "types": "./dist/convert.d.mts",
      "import": "./dist/convert.mjs"
    },
    "./format": {
      "types": "./dist/format.d.mts",
      "import": "./dist/format.mjs"
    },
    "./parse": {
      "types": "./dist/parse.d.mts",
      "import": "./dist/parse.mjs"
    },
    "./shared": {
      "types": "./dist/shared.d.mts",
      "import": "./dist/shared.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "test": "vp test",
    "lint": "vp check",
    "format": "vp check --fix"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
