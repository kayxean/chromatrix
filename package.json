{
  "name": "@kayxean/chromatrix",
  "version": "1.0.5",
  "private": false,
  "description": "CIEXYZ-based color engine using Float32Array matrix pooling",
  "keywords": [
    "accessibility",
    "color",
    "contrast",
    "conversion",
    "palette"
  ],
  "homepage": "https://github.com/kayxean/chromatrix#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kayxean/chromatrix.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./types": {
      "import": "./dist/lib/types.mjs",
      "types": "./dist/lib/types.d.mts"
    },
    "./adjust": {
      "import": "./dist/utils/adjust.mjs",
      "types": "./dist/utils/adjust.d.mts"
    },
    "./analyze": {
      "import": "./dist/utils/analyze.mjs",
      "types": "./dist/utils/analyze.d.mts"
    },
    "./contrast": {
      "import": "./dist/utils/contrast.mjs",
      "types": "./dist/utils/contrast.d.mts"
    },
    "./gamut": {
      "import": "./dist/utils/gamut.mjs",
      "types": "./dist/utils/gamut.d.mts"
    },
    "./gradient": {
      "import": "./dist/utils/gradient.mjs",
      "types": "./dist/utils/gradient.d.mts"
    },
    "./palette": {
      "import": "./dist/utils/palette.mjs",
      "types": "./dist/utils/palette.d.mts"
    },
    "./picker": {
      "import": "./dist/utils/picker.mjs",
      "types": "./dist/utils/picker.d.mts"
    },
    "./simulate": {
      "import": "./dist/utils/simulate.mjs",
      "types": "./dist/utils/simulate.d.mts"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "test": "vp test",
    "lint": "vp check",
    "format": "vp check --fix"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0"
}
