{
  "name": "@kayxean/chromatrix",
  "version": "1.0.0",
  "description": "A colorful utility for the web",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.mts",
      "import": "./dist/adapters/*.mjs"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.mts",
      "import": "./dist/utils/*.mjs"
    },
    "./convert": {
      "types": "./dist/convert.d.mts",
      "import": "./dist/convert.mjs"
    },
    "./format": {
      "types": "./dist/format.d.mts",
      "import": "./dist/format.mjs"
    },
    "./parse": {
      "types": "./dist/parse.d.mts",
      "import": "./dist/parse.mjs"
    },
    "./shared": {
      "types": "./dist/shared.d.mts",
      "import": "./dist/shared.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kayxean/chromatrix.git"
  },
  "homepage": "https://github.com/kayxean/chromatrix#readme",
  "scripts": {
    "build": "tsdown",
    "check": "biome check --write",
    "dev": "tsdown --watch",
    "format": "biome format --write",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "tsdown": "0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
